# ============================================================
# .env.example (RAÍZ) — referencia para desarrollo local
# ============================================================
# El flujo de producción es zero-CLI: no hay `pnpm bootstrap`,
# `pnpm migrate` ni `pnpm user:master`. Todo se hace desde el
# navegador vía el wizard /first-run.
#
# Para DEV LOCAL únicamente:
#   1. cp web/.env.example web/.env.local
#   2. Completar las 3 vars de Supabase en web/.env.local
#   3. cd web && pnpm dev
#
# El codegen (web/scripts/embed-provision.mjs) se corre
# automáticamente en predev/prebuild — no lo corras a mano.
# ============================================================


# ════════════════════════════════════════════════════════════
# OPCIONALES — solo para herramientas de CLI de Supabase
# ════════════════════════════════════════════════════════════

# URL pública del front (para redirects de auth).
# Dev local: http://localhost:3000 · Prod: la URL del deploy.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret para validar el webhook entrante de Kommo. Si está seteado,
# kommo-webhook exige ?secret=XXX en la URL del webhook. Vacío =
# acepta cualquier POST (no recomendado en prod). openssl rand -hex 16
KOMMO_WEBHOOK_SECRET=
