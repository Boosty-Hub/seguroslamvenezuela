# ============================================================
# web/.env.example — copiá a web/.env.local y completá
# ============================================================
# Estos valores los usa el dashboard Next.js (los lee al arrancar
# `pnpm dev`). Tras cambiarlos REINICIÁ el dev server (Ctrl-C + `pnpm dev`).
#
# ┌──────────────────────────────────────────────────────────┐
# │ OBLIGATORIAS para que el dashboard arranque (las 3 únicas):│
# │   • NEXT_PUBLIC_SUPABASE_URL                              │
# │   • NEXT_PUBLIC_SUPABASE_ANON_KEY                         │
# │   • SUPABASE_SERVICE_ROLE_KEY                             │
# └──────────────────────────────────────────────────────────┘
#
# En PRODUCCIÓN estas se configuran en el host (Netlify/Vercel) —
# no en un .env.local. El wizard /first-run muestra instrucciones
# exactas de dónde pegarlas.
#
# Son el mínimo irreducible: se necesitan para leer la DB donde vive
# runtime_config. TODO LO DEMÁS (Anthropic, identidad) se gestiona
# desde el dashboard (/setup + /agent) y se guarda en runtime_config.
# ============================================================


# ════════════════════════════════════════════════════════════
# OBLIGATORIAS — sin estas el dashboard redirige a /first-run
# ════════════════════════════════════════════════════════════

# URL pública del proyecto Supabase. Forma: https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon key. JWT LEGACY de 3 partes (empieza con eyJ...).
# NO uses las nuevas sb_publishable_* — no andan con PostgREST.
# Project Settings → API → "Legacy API keys" → "anon (public)".
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. Mismo formato/lugar ("service_role (secret)").
# Solo se usa en Route Handlers server-side. Nunca expuesto al cliente.
SUPABASE_SERVICE_ROLE_KEY=


# ════════════════════════════════════════════════════════════
# OPCIONALES — se usan desde env (no las reemplaza el wizard)
# ════════════════════════════════════════════════════════════

# Label de la pantalla de LOGIN (pre-auth). Se incrusta en el bundle al
# build (NEXT_PUBLIC_*), por eso vive acá y no en la DB. Vacío = "Agente".
# OJO: el resto del dashboard (post-login) usa el label de runtime_config
# que editás en /agent — este env SOLO afecta el login.
NEXT_PUBLIC_AGENT_LABEL=

# Hint de plataforma para el wizard /first-run (connect-supabase step).
# Si lo ponés, el wizard muestra instrucciones específicas de esa plataforma
# en lugar de mostrar el selector. Valores: netlify | vercel
# En Netlify: la var NETLIFY ya existe — no necesitás esto.
# En Vercel: NEXT_PUBLIC_VERCEL_ENV ya existe — no necesitás esto.
# Solo usalo si detección automática falla.
# NEXT_PUBLIC_HOST_HINT=netlify


# ════════════════════════════════════════════════════════════
# YA NO SE USAN ACÁ — las gestiona el dashboard (/setup + /agent).
# Están COMENTADAS a propósito: runtime_config es la fuente de verdad.
# Descomentá alguna SOLO si querés forzar un fallback de env (raro).
# ════════════════════════════════════════════════════════════

# -------- Anthropic (las escribe /setup) --------
# ANTHROPIC_API_KEY=
# ANTHROPIC_MEMORY_MASTER_ID=
# ANTHROPIC_MEMORY_LEADS_ID=

# -------- Identidad (la escribe /setup; el parser de voz la lee DB-first) --------
# OPERATOR_NAME=
